#!/bin/sh

set -eu

repo_root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
src_root="$repo_root/src"

if ! command -v rsync >/dev/null 2>&1; then
  echo "rsync is required" >&2
  exit 1
fi

copy_file() {
  source_path=$1
  target_path=$2

  if [ ! -f "$source_path" ]; then
    echo "missing source file: $source_path" >&2
    exit 1
  fi

  mkdir -p "$(dirname "$target_path")"
  printf 'copy %s -> %s\n' "$source_path" "$target_path"
  rsync -a "$source_path" "$target_path"
}

mirror_dir_contents() {
  source_path=$1
  target_path=$2

  if [ ! -d "$source_path" ]; then
    echo "missing source directory: $source_path" >&2
    exit 1
  fi

  mkdir -p "$target_path"
  printf 'copy %s/ -> %s/\n' "$source_path" "$target_path"
  rsync -a --delete "$source_path"/ "$target_path"/
}

copy_file "$HOME/.zshrc" "$src_root/.zshrc"
copy_file "$HOME/.default-gems" "$src_root/.default-gems"
copy_file "$HOME/bin/git-remove-other-branches" "$src_root/bin/git-remove-other-branches"
copy_file "$HOME/.config/alacritty/alacritty.toml" "$src_root/.config/alacritty/alacritty.toml"
mirror_dir_contents "$HOME/.config/alacritty/themes" "$src_root/.config/alacritty/themes"
copy_file "$HOME/.config/tmux/tmux.conf" "$src_root/.config/tmux/tmux.conf"
copy_file "$HOME/.config/tmux/shortpath.sh" "$src_root/.config/tmux/shortpath.sh"
