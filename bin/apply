#!/bin/sh

set -eu

repo_root=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
src_root="$repo_root/src"

if ! command -v rsync >/dev/null 2>&1; then
  echo "rsync is required" >&2
  exit 1
fi

copy_file() {
  source_path=$1
  target_path=$2

  if [ ! -f "$source_path" ]; then
    echo "missing source file: $source_path" >&2
    exit 1
  fi

  mkdir -p "$(dirname "$target_path")"
  printf 'copy %s -> %s\n' "$source_path" "$target_path"
  rsync -a "$source_path" "$target_path"
}

copy_dir_contents() {
  source_path=$1
  target_path=$2

  if [ ! -d "$source_path" ]; then
    echo "missing source directory: $source_path" >&2
    exit 1
  fi

  mkdir -p "$target_path"
  printf 'copy %s/ -> %s/\n' "$source_path" "$target_path"
  rsync -a "$source_path"/ "$target_path"/
}

copy_dir_contents "$src_root/bin" "$HOME/bin"
copy_file "$src_root/.zshrc" "$HOME/.zshrc"
copy_file "$src_root/.default-gems" "$HOME/.default-gems"
copy_dir_contents "$src_root/.config/alacritty" "$HOME/.config/alacritty"
copy_dir_contents "$src_root/.config/tmux" "$HOME/.config/tmux"
